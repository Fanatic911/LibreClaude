{
  "version": 2,
  "outputDirectory": ".",
  "rewrites": [
    { "source": "/api/chat",   "destination": "/api/chat.js" },
    { "source": "/api/links",  "destination": "/api/links.js" },
    { "source": "/api/config", "destination": "/api/config.js" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Cache-Control", "value": "no-store" }
      ]
    }
  ]
}